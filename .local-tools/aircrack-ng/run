#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
LOCAL_ROOT="$ROOT_DIR/root"
LOCAL_LIB="$ROOT_DIR/lib/libaircrack_dlopen_shim.so"

if [[ $# -eq 0 ]]; then
  printf 'usage: %s <command> [args...]\n' "$0" >&2
  exit 1
fi

export AIRCRACK_LOCAL_ROOT="$LOCAL_ROOT"
export PATH="$LOCAL_ROOT/usr/bin:$LOCAL_ROOT/usr/sbin:$PATH"
export LD_LIBRARY_PATH="$LOCAL_ROOT/usr/lib/x86_64-linux-gnu:$LOCAL_ROOT/usr/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
export LD_PRELOAD="$LOCAL_LIB${LD_PRELOAD:+:$LD_PRELOAD}"

exec "$@"
