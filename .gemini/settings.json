{
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "touch /home/csr1/my-awi-instance/hook_fired.txt && bash /home/csr1/my-awi-instance/.gemini/hooks/permission-sound.sh"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "write_file|replace|run_shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/csr1/my-awi-instance/.gemini/hooks/auto-commit.sh",
            "timeout": 30000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/csr1/my-awi-instance/.gemini/hooks/victory-sound.sh"
          }
        ]
      }
    ]
  }
}
